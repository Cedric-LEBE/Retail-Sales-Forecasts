{
  "uid": "retail-docker",
  "title": "Retail • Docker Containers Overview",
  "tags": ["retail", "docker", "cadvisor"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 9,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU usage by container",
      "datasource": "Prometheus",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "cores"
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "retail-streamlit",
          "expr": "sum(rate(container_cpu_usage_seconds_total{id=~\".*/docker-32fd070da0bc.*\"}[2m]))"
        },
        {
          "refId": "B",
          "legendFormat": "retail-mlflow",
          "expr": "sum(rate(container_cpu_usage_seconds_total{id=~\".*/docker-4b21403f71c1.*\"}[2m]))"
        },
        {
          "refId": "C",
          "legendFormat": "retail-airflow-webserver",
          "expr": "sum(rate(container_cpu_usage_seconds_total{id=~\".*/docker-37c2826f2684.*\"}[2m]))"
        },
        {
          "refId": "D",
          "legendFormat": "retail-airflow-scheduler",
          "expr": "sum(rate(container_cpu_usage_seconds_total{id=~\".*/docker-4defafada9a5.*\"}[2m]))"
