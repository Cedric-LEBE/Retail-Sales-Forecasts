          "legendFormat": "retail-nginx",
          "expr": "sum(rate(container_cpu_usage_seconds_total{id=~\".*/docker-60248ad8548e.*\"}[2m]))"
        },
        {
          "refId": "H",
          "legendFormat": "retail-minio",
          "expr": "sum(rate(container_cpu_usage_seconds_total{id=~\".*/docker-8299bfc8026f.*\"}[2m]))"
